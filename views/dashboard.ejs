<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stock Portfolio Tracker | Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0f172a;
            color: #e2e8f0;
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8">
    <div class="max-w-7xl mx-auto">
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-white tracking-tight">Portfolio Dashboard</h1>
                <p class="text-slate-400 mt-1">Real-time valuation based on Yahoo Finance</p>
            </div>
            <a href="/" class="bg-slate-700 hover:bg-slate-600 text-white px-4 py-2 rounded-lg font-medium transition-colors border border-slate-600 shadow-sm flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                Upload New File
            </a>
        </header>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 shadow-lg">
                <h3 class="text-slate-400 text-sm font-medium mb-1">Total Invested</h3>
                <p class="text-3xl font-bold text-white">₹<%= portfolio.summary.totalInvested.toLocaleString('en-IN', { maximumFractionDigits: 2 }) %></p>
            </div>
            <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 shadow-lg">
                <h3 class="text-slate-400 text-sm font-medium mb-1">Current Value</h3>
                <p class="text-3xl font-bold text-white">₹<%= portfolio.summary.totalCurrentValue.toLocaleString('en-IN', { maximumFractionDigits: 2 }) %></p>
            </div>
            <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 shadow-lg">
                <h3 class="text-slate-400 text-sm font-medium mb-1">Net P&L</h3>
                <p class="text-3xl font-bold <%= portfolio.summary.totalPnl >= 0 ? 'text-emerald-400' : 'text-rose-400' %>">
                    <%= portfolio.summary.totalPnl >= 0 ? '+' : '' %>₹<%= portfolio.summary.totalPnl.toLocaleString('en-IN', { maximumFractionDigits: 2 }) %>
                </p>
                <% const pnlPercent = (portfolio.summary.totalPnl / portfolio.summary.totalInvested) * 100; %>
                <p class="text-sm mt-1 <%= pnlPercent >= 0 ? 'text-emerald-500/80' : 'text-rose-500/80' %> font-medium">
                    <%= pnlPercent >= 0 ? '+' : '' %><%= pnlPercent.toFixed(2) %>%
                </p>
            </div>
        </div>

        <!-- Holdings Table -->
        <div class="bg-slate-800 rounded-2xl border border-slate-700 shadow-lg overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-900/50 text-slate-400 text-sm border-b border-slate-700">
                            <th class="px-6 py-4 font-medium">Instrument</th>
                            <th class="px-6 py-4 font-medium text-right">Qty</th>
                            <th class="px-6 py-4 font-medium text-right">Avg Cost</th>
                            <th class="px-6 py-4 font-medium text-right">LTP (Live)</th>
                            <th class="px-6 py-4 font-medium text-right">Invested</th>
                            <th class="px-6 py-4 font-medium text-right">Current Val</th>
                            <th class="px-6 py-4 font-medium text-right">P&L</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-700/50 text-sm">
                        <% portfolio.holdings.forEach(item => { %>
                            <tr class="hover:bg-slate-700/25 transition-colors">
                                <td class="px-6 py-4 font-medium text-white"><%= item.instrument %></td>
                                <td class="px-6 py-4 text-right text-slate-300"><%= item.quantity %></td>
                                <td class="px-6 py-4 text-right text-slate-300">₹<%= item.avgCost.toFixed(2) %></td>
                                <td class="px-6 py-4 text-right font-medium text-white">₹<%= item.currentPrice.toFixed(2) %></td>
                                <td class="px-6 py-4 text-right text-slate-300">₹<%= item.invested.toLocaleString('en-IN', { maximumFractionDigits: 2 }) %></td>
                                <td class="px-6 py-4 text-right text-slate-300">₹<%= item.currentValue.toLocaleString('en-IN', { maximumFractionDigits: 2 }) %></td>
                                <td class="px-6 py-4 text-right font-medium <%= item.pnl >= 0 ? 'text-emerald-400' : 'text-rose-400' %>">
                                    <%= item.pnl >= 0 ? '+' : '' %>₹<%= item.pnl.toLocaleString('en-IN', { maximumFractionDigits: 2 }) %>
                                    <% const itemPnlPercent = (item.pnl / item.invested) * 100; %>
                                    <span class="block text-xs <%= item.pnl >= 0 ? 'text-emerald-500/70' : 'text-rose-500/70' %> mt-0.5">
                                        <%= itemPnlPercent >= 0 ? '+' : '' %><%= itemPnlPercent.toFixed(2) %>%
                                    </span>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
